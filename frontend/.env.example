# URL of the Express backend (used by Next.js rewrites to proxy /api/* and /uploads/*)
NEXT_PUBLIC_BACKEND_URL="http://localhost:4000"

# JWT secret — must be identical to the one in backend/.env
JWT_SECRET="your-secure-jwt-secret-key-at-least-32-chars"

# Public app URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
