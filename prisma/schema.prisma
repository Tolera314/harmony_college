generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  REGISTRAR_OFFICER
  FINANCE_OFFICER
  HR_OFFICER
  LECTURER
  STUDENT
  DEPARTMENT_HEAD
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  passwordHash String
  role         Role         @default(STUDENT)
  application  Application?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Application {
  id               String     @id @default(uuid())
  userId           String     @unique
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Step 1: Personal
  fullName         String
  dob              DateTime
  age              Int
  gender           String
  
  // Step 2: Contact
  nationality      String
  emergencyContact String
  phone            String
  city             String
  address          String
  
  // Step 3: Academic
  program          String
  academicYear     String
  semester         String
  studyMode        String
  
  // Status & Timestamps
  status           String     @default("DRAFT") // "DRAFT", "SUBMITTED", "UNDER_REVIEW", "ACCEPTED", "REJECTED"
  documents        Document[]
  submittedAt      DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model Document {
  id            String       @id @default(uuid())
  applicationId String
  application   Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  type          String       // "MATRIC", "GRADE_8", "TRANSCRIPT_9_10", "TRANSCRIPT_11_12"
  fileUrl       String
  uploadedAt    DateTime     @default(now())
}
